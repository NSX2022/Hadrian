<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="controllers.ChatsController">
  <grid id="27dc6" binding="contentPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="859" height="503"/>
    </constraints>
    <properties>
      <minimumSize width="400" height="200"/>
      <preferredSize width="400" height="200"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="8c8eb" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="5" left="5" bottom="5" right="5"/>
        <constraints border-constraint="West"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="c8d34" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="// All Chats"/>
            </properties>
          </component>
          <vspacer id="2630b">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
            </constraints>
          </vspacer>
          <component id="6bc54" class="javax.swing.JButton" binding="backButton">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="&lt; Back"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="11ebc" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="East"/>
        <properties>
          <minimumSize width="-1" height="-1"/>
          <preferredSize width="300" height="-1"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="3e787" class="javax.swing.JTextField" binding="usersField">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="2" hsize-policy="6" anchor="9" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="a4ac" class="javax.swing.JTextArea" binding="messageArea">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="6" anchor="0" fill="3" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="50"/>
              </grid>
            </constraints>
            <properties>
              <lineWrap value="true"/>
            </properties>
          </component>
          <component id="49140" class="javax.swing.JButton" binding="createChatButton">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="2" hsize-policy="7" anchor="2" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="&gt; Create Chat"/>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="cf0d3">
        <constraints border-constraint="Center"/>
        <properties>
          <autoscrolls value="true"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="6d391" binding="chatsPanel" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints/>
            <properties>
              <autoscrolls value="true"/>
              <preferredSize width="230" height="200"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>
